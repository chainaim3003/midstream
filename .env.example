# ============================================================================
# Midstream — environment template
# Copy to .env.local. Never commit .env.local.
# ============================================================================

# ----------------------------------------------------------------------------
# Chain
# ----------------------------------------------------------------------------
# The Circle SDK knows the Arc testnet RPC, chain ID, USDC contract, and
# Gateway Wallet address internally — we just name the chain.
# Do not override unless you know what you're doing.
# CHAIN=arcTestnet

# Block explorer — used only for display in scripts/UI.
ARC_BLOCK_EXPLORER_URL=https://testnet.arcscan.app

# ----------------------------------------------------------------------------
# Wallets
# ----------------------------------------------------------------------------
# Populated by `npm run generate-wallets`. The buyer must be funded with Arc
# testnet USDC from https://faucet.circle.com/ and have a Gateway deposit via
# `npm run deposit 5`.

BUYER_PRIVATE_KEY=
BUYER_ADDRESS=
SELLER_PRIVATE_KEY=
SELLER_ADDRESS=

# ----------------------------------------------------------------------------
# LLM providers
# ----------------------------------------------------------------------------

# Seller-side. Streams the paid LLM output per chunk.
# https://console.anthropic.com/
# Model IDs change over time; check docs.anthropic.com/en/docs/about-claude/models
# if this one stops working.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Buyer-side judge for the text oracle. Runs Gemini 2.5 Flash with Function
# Calling to score cumulative output.
# Paid tier recommended — free tier is 5 requests/min which will not sustain
# a 4-session demo. Enable paid tier at https://aistudio.google.com/apikey.
# Paid-tier cost for full demo: ~$0.01. See GEMINI_MAX_COST_USD below.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Hard cost cap for the Gemini judge across a single demo run. Checked
# between sessions; if the estimated spend reaches this, remaining sessions
# are skipped. Default $1.00 is ~100× the actual expected spend, so this is
# a safety cap, not a normal budget.
GEMINI_MAX_COST_USD=1.00

# ----------------------------------------------------------------------------
# Ports
# ----------------------------------------------------------------------------
# Used as the default when process.env.PORT is unset (i.e. local dev). On
# Railway / Fly / Render the platform injects PORT and the entry points
# bind to that instead, so these values are only consulted locally.

SELLER_PORT=3000
WEB_SERVER_PORT=3001

# ----------------------------------------------------------------------------
# Deployment — only needed when running seller and web-server as separate
# services (e.g. two services on Railway, or seller on Fly + dashboard on
# Vercel-static). Leave both unset for local dev.
# ----------------------------------------------------------------------------

# Public base URL of the seller service. The web-server uses this to reach
# the seller for paid /chunk/* requests. If unset, the web-server defaults
# to http://localhost:${SELLER_PORT}.
# Example: SELLER_BASE_URL=https://midstream-seller-abc123.up.railway.app
SELLER_BASE_URL=

# Shared secret for authenticating the dangerous POST /api/evidence/produce
# endpoint, which spends real testnet USDC by calling GatewayClient.deposit
# (capped at 20 deposits per call). Without this, anyone who finds the
# public dashboard URL can drain testnet USDC out of the buyer wallet.
# Leave unset for local dev — endpoint stays open. In production, set a
# long random string and pass it via the `X-Demo-Key` request header.
# Example: DEMO_KEY=$(openssl rand -hex 32)
DEMO_KEY=

# ----------------------------------------------------------------------------
# Per-session defaults (UI can override)
# ----------------------------------------------------------------------------

# Price per paid chunk. Must be ≤ $0.01 (hackathon rule).
PRICE_PER_CHUNK_USDC=0.0005

# Max tokens per chunk (Anthropic max_tokens parameter).
CHUNK_SIZE_TOKENS=32

# Hard ceiling per session. Buyer refuses to start if budget exceeded.
MAX_TOKENS_PER_SESSION=1000
BUYER_MAX_SPEND_USDC=1.0

# Quality gate parameters.
QUALITY_THRESHOLD=0.60
ROLLING_WINDOW_SIZE=3
WARMUP_CHUNKS=2

# Server housekeeping.
SESSION_IDLE_TIMEOUT_SECONDS=60
