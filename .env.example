# ============================================================================
# agentic_economy_refined — environment template
# Copy to .env.local. Never commit .env.local.
# ============================================================================

# ----------------------------------------------------------------------------
# Chain
# ----------------------------------------------------------------------------
# The Circle SDK knows the Arc testnet RPC, chain ID, USDC contract, and
# Gateway Wallet address internally — we just name the chain.
# Do not override unless you know what you're doing.
# CHAIN=arcTestnet

# Block explorer — used only for display in scripts/UI.
ARC_BLOCK_EXPLORER_URL=https://testnet.arcscan.app

# ----------------------------------------------------------------------------
# Wallets
# ----------------------------------------------------------------------------
# Populated by `npm run generate-wallets`. The buyer must be funded with Arc
# testnet USDC from https://faucet.circle.com/ and have a Gateway deposit via
# `npm run deposit 5`.

BUYER_PRIVATE_KEY=
BUYER_ADDRESS=
SELLER_PRIVATE_KEY=
SELLER_ADDRESS=

# ----------------------------------------------------------------------------
# LLM providers
# ----------------------------------------------------------------------------

# Seller-side. Streams the paid LLM output per chunk.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Buyer-side judge for the text oracle. Runs Gemini 2.5 Flash with Function
# Calling to score cumulative output.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# Ports
# ----------------------------------------------------------------------------

SELLER_PORT=3000
WEB_SERVER_PORT=3001

# ----------------------------------------------------------------------------
# Per-session defaults (UI can override)
# ----------------------------------------------------------------------------

# Price per paid chunk. Must be ≤ $0.01 (hackathon rule).
PRICE_PER_CHUNK_USDC=0.0005

# Max tokens per chunk (Anthropic max_tokens parameter).
CHUNK_SIZE_TOKENS=32

# Hard ceiling per session. Buyer refuses to start if budget exceeded.
MAX_TOKENS_PER_SESSION=1000
BUYER_MAX_SPEND_USDC=1.0

# Quality gate parameters.
QUALITY_THRESHOLD=0.60
ROLLING_WINDOW_SIZE=3
WARMUP_CHUNKS=2

# Server housekeeping.
SESSION_IDLE_TIMEOUT_SECONDS=60
